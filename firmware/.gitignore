# Phase 6 OTA F2 — signing-key material. The private key MUST
# never be committed; the public key is generated at build time
# from the private (or from CI's OTA_SIGNING_KEY secret) so
# nothing in scripts/secrets/ needs to be tracked.
scripts/secrets/

# Auto-generated by scripts/embed-pubkey.py — regenerated on
# every release build, no value in committing.
src/application/SigningPublicKey.h
