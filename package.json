{
  "name": "howler",
  "private": true,
  "version": "0.0.1",
  "description": "Howler — generic task tracker (PWA + ESP32 dial). See docs/plan.md.",
  "scripts": {
    "dev:backend": "pnpm --filter howler-backend dev",
    "dev:webapp": "pnpm --filter howler-webapp dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter howler-backend db:generate",
    "db:migrate:local": "pnpm --filter howler-backend db:migrate:local",
    "db:migrate:remote": "pnpm --filter howler-backend db:migrate:remote",
    "deploy:backend": "pnpm --filter howler-backend deploy",
    "deploy:webapp": "pnpm --filter howler-webapp deploy"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  }
}
